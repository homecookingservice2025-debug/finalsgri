# Port configuration for Server and WebSockets ingress
PORT=3000

# Supabase database access variables (Server-side API keys and Vite fallbacks)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-public-anon-key

# Admin user authorization configurations
ADMIN_ID=admin
ADMIN_PASSWORD=12345

# Client-side VPS API/WS URL (only needed for static hosts like Vercel - leave blank for local development)
VITE_API_URL=http://your-ubuntu-vps-ip:3000
