{
  "version": 2,
  "name": "enterprise-whatsapp-crm",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "http://your-ubuntu-vps-ip:3000/socket.io/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
